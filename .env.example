# =============================================================================
# grounded-horticulture — copy to .env and fill in values
# cp .env.example .env
# =============================================================================

# --- Go API (server) ---
SERVER_PORT=8080

# Python service (in Docker — compose service names)
CLASSIFIER_URL=http://classifier:5000/classify
CLASSIFIER_RAG_URL=http://classifier:5000/rag/context

# --- LLM (only these variables; OPENROUTER_API_KEY is not used) ---
# Put your OpenRouter key in LLM_API_KEY (sk-or-v1-... from openrouter.ai/keys).
LLM_API_KEY=
LLM_BASE_URL=https://openrouter.ai/api
# Do not use openrouter/free — queue, 429, slow responses.
# Recommended for pilot: google/gemini-2.5-flash-lite (~$0.10/$0.40 per 1M tokens).
# Alternative: openai/gpt-4o-mini (~$0.15/$0.60).
LLM_MODEL=google/gemini-2.5-flash-lite

# --- Telegram Web App (for users from the bot) ---
# Bot token from @BotFather — for initData signature verification
TELEGRAM_BOT_TOKEN=

# --- Browser / API clients (web without Telegram, integrations) ---
# Option 1: comma-separated — key or key:label
# API_KEYS=your-long-random-key:browser-demo
# Option 2: JSON file (see config/api_keys.example.json)
# API_KEYS_FILE=/config/api_keys.json

# Local development without Telegram: true (do NOT use in production)
TELEGRAM_AUTH_DISABLED=false

# Maximum initData age (seconds), replay protection
TELEGRAM_INIT_DATA_MAX_AGE_SEC=86400

# --- CORS (comma-separated, spaces trimmed) ---
# Example: https://your-domain.com,http://localhost,http://127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1

# --- Rate limit (per Telegram user_id) ---
RATE_LIMIT_REQUESTS_PER_MINUTE=30

# --- PostgreSQL (sessions and messages) ---
# Production: MUST change POSTGRES_PASSWORD, ADMIN_PASSWORD, ADMIN_SECRET.
POSTGRES_PASSWORD=gardener
DATABASE_URL=postgres://gardener:gardener@postgres:5432/gardener?sslmode=disable

# Directory for uploaded photos (volume in Docker)
UPLOAD_DIR=/data/uploads

# --- Go: paths to JSON configs (optional; default /config or ./config) ---
# CROPS_CONFIG_PATH=config/crops.json
# PROMPTS_CONFIG_PATH=config/prompts.json
# PHOTO_TEMPLATES_PATH=config/photo_templates.json
# ONBOARDING_CONFIG_PATH=config/onboarding.json
# BRANDING_CONFIG_PATH=config/branding.json
# CONFIG_RELOAD_INTERVAL_SEC=0
# SIGHUP on the server process reloads JSON without restart

# --- Python CV: class labels per crop ---
# CV_CLASS_LABELS_PATH=config/cv_class_labels.json

# --- Python service (api + cv; compose service classifier) ---
CLASSIFIER_PORT=5000
# Docker: gunicorn (1 worker + N threads — shared ML models in memory)
# GUNICORN_WORKERS=1
# GUNICORN_THREADS=4
# GUNICORN_TIMEOUT=300
# Local: python api/app.py (Flask threaded) or USE_GUNICORN=true python api/app.py
MODEL_PATH=models/apple_classifier.pth

# HuggingFace Hub (e5 embeddings, bge-reranker) — higher rate limit during docker build and startup
# Required for stable classifier image build on CI/production
# HF_TOKEN=hf_xxxxxxxx
# HF_HOME=/app/hf_cache  (set in compose for Docker; locally — hf_cache in repo root)
# SKIP_HF_BAKE=1  — skip model download during docker build (fast CI)
# Classifier Docker image: PyTorch CPU-only (see Dockerfile.classifier + cv/requirements-docker.txt)

# Recreate Chroma + BM25 after data/, chunking, or embedding changes
FORCE_RAG_REINDEX=false

# RAG hybrid (vector + BM25 RRF) and cross-encoder reranker
# RAG_WARMUP_ENABLED=true
# RAG_WARMUP_QUERY=apple scab leaf symptoms
# AGRO_GLOSSARY_PATH=/config/agro_glossary.json
# RAG_HYBRID_ENABLED=true
# RAG_RERANK_ENABLED=true
# RAG_RERANK_CONDITIONAL=true
# RAG_RERANK_ALWAYS=false
# RAG_RERANK_CATEGORIES=rootstock,disease,variety,fertilizer,relief
# RAG_FETCH_K=16
# RAG_BM25_FETCH_K=16
# RAG_RRF_K=60
# RAG_RERANK_TOP_N=16
# RAG_RERANK_MODEL=BAAI/bge-reranker-base
# RAG_MAX_CHUNKS_PER_SOURCE=2
# RAG_DEBUG=false

# --- Admin (session 5) ---
# Basic auth for /api/admin/* and article upload
ADMIN_USER=admin
# Production: set a long password and ADMIN_SECRET (reindex, upload).
ADMIN_PASSWORD=
# Secret for POST /admin/reindex on Python (must match on server and classifier)
ADMIN_SECRET=

# CORS for Python classifier (same list as Go server)
# CORS_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1

# Article directory on Go server (in Docker — volume ./data)
DATA_DIR=/app/data
PYTHON_BASE_URL=http://classifier:5000
