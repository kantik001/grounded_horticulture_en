# =============================================================================
# doctor_gardens_ai — скопируйте в .env и заполните значения
# cp .env.example .env
# =============================================================================

# --- Go API (server) ---
SERVER_PORT=8080

# Python-сервис (в Docker — имена сервисов compose)
CLASSIFIER_URL=http://classifier:5000/classify
CLASSIFIER_RAG_URL=http://classifier:5000/rag/context

# --- LLM (только эти переменные; OPENROUTER_API_KEY не используется) ---
# Ключ OpenRouter вставляйте в LLM_API_KEY (sk-or-v1-... с openrouter.ai/keys).
LLM_API_KEY=
LLM_BASE_URL=https://openrouter.ai/api
# Не используйте openrouter/free — авто-роутер нестабилен на русском.
# Бесплатные модели: openai/gpt-oss-120b:free, z-ai/glm-4.5-air:free,
# nvidia/nemotron-3-super-120b-a12b:free
LLM_MODEL=openai/gpt-oss-120b:free

# --- Telegram Web App (обязательно для продакшена) ---
# Токен бота от @BotFather — для проверки подписи initData
TELEGRAM_BOT_TOKEN=

# Локальная разработка без Telegram: true (НЕ использовать в продакшене)
TELEGRAM_AUTH_DISABLED=false

# Максимальный возраст initData (секунды), защита от replay
TELEGRAM_INIT_DATA_MAX_AGE_SEC=86400

# --- CORS (через запятую, без пробелов или с пробелами — обрежутся) ---
# Пример: https://your-domain.com,http://localhost,http://127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1

# --- Rate limit (на одного Telegram user_id) ---
RATE_LIMIT_REQUESTS_PER_MINUTE=30

# --- PostgreSQL (сессии и сообщения) ---
# Продакшен: ОБЯЗАТЕЛЬНО смените POSTGRES_PASSWORD, ADMIN_PASSWORD, ADMIN_SECRET.
POSTGRES_PASSWORD=gardener
DATABASE_URL=postgres://gardener:gardener@postgres:5432/gardener?sslmode=disable

# Каталог для загруженных фото (volume в Docker)
UPLOAD_DIR=/data/uploads

# --- Go: пути к JSON-конфигам (опционально, по умолчанию /config или ./config) ---
# CROPS_CONFIG_PATH=config/crops.json
# PROMPTS_CONFIG_PATH=config/prompts.json
# PHOTO_TEMPLATES_PATH=config/photo_templates.json
# ONBOARDING_CONFIG_PATH=config/onboarding.json
# BRANDING_CONFIG_PATH=config/branding.json
# CONFIG_RELOAD_INTERVAL_SEC=0
# SIGHUP на процесс server перечитывает JSON без рестарта

# --- Python CV: метки классов по культурам ---
# CV_CLASS_LABELS_PATH=config/cv_class_labels.json

# --- Python-сервис (api + cv; compose-сервис classifier) ---
CLASSIFIER_PORT=5000
MODEL_PATH=models/apple_classifier.pth

# HuggingFace Hub (e5 embeddings, bge-reranker) — выше rate limit, быстрее первый RAG
# HF_TOKEN=hf_xxxxxxxx

# Пересоздать Chroma + BM25 после смены data/, chunking или embeddings
FORCE_RAG_REINDEX=false

# RAG hybrid (vector + BM25 RRF) и cross-encoder reranker
# RAG_HYBRID_ENABLED=true
# RAG_RERANK_ENABLED=true
# RAG_FETCH_K=24
# RAG_BM25_FETCH_K=24
# RAG_RRF_K=60
# RAG_RERANK_TOP_N=32
# RAG_RERANK_MODEL=BAAI/bge-reranker-base
# RAG_MAX_CHUNKS_PER_SOURCE=2

# --- Админка (сессия 5) ---
# Basic auth для /api/admin/* и загрузка статей
ADMIN_USER=admin
# Продакшен: обязательно задайте длинный пароль и ADMIN_SECRET (reindex, upload).
ADMIN_PASSWORD=
# Секрет для POST /admin/reindex на Python (должен совпадать у server и classifier)
ADMIN_SECRET=

# CORS для Python classifier (тот же список, что у Go server)
# CORS_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1

# Каталог статей на Go-сервере (в Docker — volume ./data)
DATA_DIR=/app/data
PYTHON_BASE_URL=http://classifier:5000
